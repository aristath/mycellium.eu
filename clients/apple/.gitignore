# SwiftPM build output
.build/
.swiftpm/
Package.resolved

# Rust/binding build artifacts produced by build-rust.sh — regenerated, never committed:
#   - the generated UniFFI Swift binding
Sources/MyceliumSDK/Generated/
#   - the generated C ABI header (the committed module.modulemap references it)
Sources/mycellium_sdkFFI/*.h

# Host + Apple native libraries (build artifacts)
*.so
*.dylib
*.a

# The Apple xcframework built by the documented `build-rust.sh` Apple path
*.xcframework/
MyceliumFFI.xcframework/

# Xcode project (generated by XcodeGen from App/project.yml) + derived data
*.xcodeproj/
DerivedData/
*.xcworkspace/
.DS_Store
