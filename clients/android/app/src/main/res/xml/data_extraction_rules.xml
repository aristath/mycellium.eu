<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup / device-transfer rules. Exclude the wrapped identity blob
  and the encrypted store from both cloud backup and device-to-device transfer,
  so the account root key never leaves this device via restore. Account recovery
  is handled by email re-binding instead (issue #6). See
  docs/research/SECURE-STORAGE.md §5.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="secretstore/" />
        <exclude domain="file" path="store" />
        <exclude domain="file" path="identity.json" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="secretstore/" />
        <exclude domain="file" path="store" />
        <exclude domain="file" path="identity.json" />
    </device-transfer>
</data-extraction-rules>
