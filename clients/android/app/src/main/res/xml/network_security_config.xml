<?xml version="1.0" encoding="utf-8"?>
<!-- Cleartext HTTP is permitted ONLY to local development directory/queue servers
     (the emulator reaches the host loopback at 10.0.2.2). Every other host falls
     under the default policy, which requires HTTPS — production directory/queue
     URLs are HTTPS. This keeps `http://` usable for local dev + the on-device e2e
     test without weakening transport security for real deployments. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
