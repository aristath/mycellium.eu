<?xml version="1.0" encoding="utf-8"?>
<!--
  Legacy Auto Backup rules (Android 11 and below). Belt-and-suspenders on top of
  android:allowBackup="false": explicitly exclude the wrapped identity blob and
  the SDK's encrypted store so the account's key material is never shipped to a
  place a different device's OS could later unwrap. See
  docs/research/SECURE-STORAGE.md §5.
-->
<full-backup-content>
    <exclude domain="file" path="secretstore/" />
    <exclude domain="file" path="store" />
    <exclude domain="file" path="identity.json" />
</full-backup-content>
